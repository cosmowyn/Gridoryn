{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Gridoryn: Launch app",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "python": "${command:python.interpreterPath}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Gridoryn: Run buildfile",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/buildfile.py",
            "cwd": "${workspaceFolder}",
            "python": "${command:python.interpreterPath}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Gridoryn: Run pytest",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "python": "${command:python.interpreterPath}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "tests",
                "-q"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}
